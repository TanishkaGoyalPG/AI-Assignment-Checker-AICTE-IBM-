# ─────────────────────────────────────────────────────────────────────────────
#  IBM Watsonx.ai  –  Plagiarism Intelligence System
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

IBM_API_KEY=your_ibm_cloud_api_key_here
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com
IBM_PROJECT_ID=your_watsonx_project_id_here

# Granite model to use for analysis
#   ibm/granite-13b-instruct-v2   (default, balanced)
#   ibm/granite-3-8b-instruct     (faster, lighter)
#   ibm/granite-20b-multilingual  (multilingual support)
GRANITE_MODEL_ID=ibm/granite-13b-instruct-v2

# Flask secret key – change to a long random string in production
FLASK_SECRET_KEY=change_me_to_a_long_random_secret

# Optional: max file upload size in MB (default 10)
MAX_UPLOAD_MB=10
